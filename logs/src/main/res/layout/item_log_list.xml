<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_log_gray_r8"
    android:layout_marginVertical="3dp"
    android:paddingHorizontal="8dp"
    android:layout_marginHorizontal="8dp"
    android:paddingBottom="8dp"
    >

    <!-- Top row: ID, Level Badge, Time -->

    <TextView
        android:id="@+id/tvIdTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:text="ID:"
        android:layout_marginTop="8dp"
        android:textSize="8sp"
        android:paddingVertical="2dp"
        android:textStyle="bold"
        android:textColor="#64748B"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/tvId"
        android:layout_marginStart="4dp"
        android:layout_marginTop="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#03A9F4"
        android:paddingVertical="2dp"
        android:textSize="9sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/tvIdTitle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/tvIdTitle"
        tools:text="TX-4092" />

    <TextView
        android:id="@+id/tvLevel"
        android:layout_width="wrap_content"
        android:layout_height="12dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="8sp"
        android:textStyle="bold"
        android:paddingHorizontal="8dp"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@+id/tvId"
        app:layout_constraintTop_toTopOf="@+id/tvId"
        app:layout_constraintBottom_toBottomOf="@+id/tvId"
        tools:text="DEBUG" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#64748B"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvId"
        tools:text="14:22:05.812" />



    <TextView
        android:id="@+id/tvTag"
        style="@style/style_item_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#34D399"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ivImageThumb"
        app:layout_constraintTop_toBottomOf="@+id/tvId"
        tools:text="MainActivity" />
    <TextView
        android:id="@+id/tvMethod"
        style="@style/style_item_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#64748B"
        android:textSize="11sp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ivImageThumb"
        app:layout_constraintTop_toBottomOf="@+id/tvTag"
        tools:text="outFile" />

    <!-- Message -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/translucent_white_20"
        android:textSize="10sp"
        android:lineSpacingMultiplier="1.2"
        android:paddingHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:paddingVertical="4dp"
        android:background="@drawable/bg_log_message"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvMethod"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="External socket established via encrypted handshake. Packet integrity verified by node-7." />

    <!-- Image Thumbnail Icon on the right -->
    <ImageView
        android:id="@+id/ivImageThumb"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:contentDescription="@string/preview_image"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvTag"
        app:layout_constraintBottom_toBottomOf="@+id/tvMethod"
        tools:srcCompat="@android:drawable/ic_menu_gallery" />
</androidx.constraintlayout.widget.ConstraintLayout>

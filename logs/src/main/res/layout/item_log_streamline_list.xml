<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_gray_r8"
    android:paddingHorizontal="8dp">

    <!-- Top row: ID, Level Badge, Time -->

    <LinearLayout
        android:id="@+id/llId"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginVertical="6dp"
        android:background="@drawable/bg_id"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvIdTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ID"
            android:textColor="#64748B"
            android:textSize="6sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="4dp"
            android:textColor="#03A9F4"
            android:textSize="7sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/tvIdTitle"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="92100" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llLevel"
        android:layout_width="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/tvMessage"
        app:layout_constraintStart_toEndOf="@+id/llId"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="@+id/llId"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/tvLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="7sp"
            tools:text="DEBUG" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:textColor="#64748B"
            android:textSize="7sp"
            app:layout_constraintStart_toEndOf="@+id/tvLevel"
            app:layout_constraintTop_toTopOf="@+id/llId"
            app:layout_constraintBottom_toTopOf="@+id/tvMessage"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="14:22:05.812" />
    </LinearLayout>
    <!-- Message -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.2"
        android:maxLines="1"
        android:textColor="@color/translucent_white_20"
        android:textSize="8sp"
        app:layout_constraintBottom_toBottomOf="@id/llId"
        app:layout_constraintEnd_toStartOf="@+id/ivImageThumb"
        app:layout_constraintStart_toEndOf="@+id/llId"
        app:layout_constraintTop_toBottomOf="@+id/llLevel"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="External socket established via encrypted handshake. Packet integrity verified by node-7." />

    <!-- Image Thumbnail Icon on the right -->
    <ImageView
        android:id="@+id/ivImageThumb"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:contentDescription="@string/preview_image"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@android:drawable/ic_menu_gallery" />
</androidx.constraintlayout.widget.ConstraintLayout>

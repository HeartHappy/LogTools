<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.hearthappy.log.preview.PreviewLogActivity">


    <ImageView
        android:id="@+id/ivLogBack"
        style="@style/style_icon"
        android:layout_margin="@dimen/dp_12"
        android:src="@drawable/ic_log_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvLogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/system_logs"
        android:textColor="@color/color_base_white"
        android:textSize="@dimen/sp_16"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/ivLogBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/ivLogBack" />

    <ImageView
        android:id="@+id/ivStreamline"
        style="@style/style_icon"
        android:layout_margin="@dimen/dp_12"
        android:src="@drawable/ic_log_streamline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_6"
        app:tabMinWidth="0dp"
        app:tabPaddingStart="@dimen/dp_12"
        app:tabPaddingEnd="@dimen/dp_12"
        app:tabTextAppearance="@style/MyTabTextStyle"
        app:layout_constraintTop_toBottomOf="@+id/ivLogBack"
        app:tabMode="scrollable" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tabLayout" />
</androidx.constraintlayout.widget.ConstraintLayout>